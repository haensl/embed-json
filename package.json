{
  "name": "embed-json",
  "version": "1.2.10",
  "description": "Inline/Embed JSON data from files into HTML.",
  "keywords": [
    "inline",
    "embed",
    "json",
    "html"
  ],
  "main": "index.js",
  "scripts": {
    "precommit": "npm run lint && npm test",
    "postinstall": "if [ \"${NODE_ENV}\" != 'production' ] && [ -z \"${CI}\" ]; then ./setup-hooks.sh; fi",
    "test": "mocha",
    "test:ci": "mocha --reporter mocha-junit-reporter --reporter-options mochaFile=./test-results/mocha/results.xml",
    "tdd": "mocha --watch",
    "lint": "eslint *.js **/*.js",
    "lint:ci": "eslint --format junit -o test-results/eslint/results.xml *.js **/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haensl/embed-json.git"
  },
  "author": {
    "name": "HP Dietz",
    "email": "h.p.dietz@gmail.com",
    "url": "https://hpdietz.com"
  },
  "funding": "https://github.com/sponsors/haensl",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/haensl/embed-json/issues"
  },
  "homepage": "https://github.com/haensl/embed-json#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@haensl/eslint-config": "^2.0.0",
    "chai": "^4.2.0",
    "eslint": "^10.0.3",
    "eslint-formatter-junit": "^9.0.1",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "^2.0.0"
  }
}
